# mental-barrier LLM 配置文件
# 用法: cp .env.example .env 然后填入你的 API Key
#       source .env 或在 batch_run_llm.py 中选择模型
#
# 切换模型: python3 batch_run_llm.py --model minimax
#           python3 batch_run_llm.py --model deepseek

# ===== MiniMax =====
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ===== DeepSeek =====
# 使用当前 Claude Code 会话的凭证（DEEPSEEK_API_KEY 从环境变量继承）
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro[1m]

# ===== LIANGREKUI (Claude Sonnet 4.6) =====
LIANGREKUI_API_KEY=YOUR_LIANGREKUI_API_KEY_HERE
LIANGREKUI_BASE_URL=https://api.liangrekui.com/
LIANGREKUI_MODEL=claude-sonnet-4-6

# ===== LIANGREKUI-GPT (GPT-5.4) =====
LIANGREKUI_GPT_API_KEY=YOUR_LIANGREKUI_GPT_API_KEY_HERE
LIANGREKUI_GPT_BASE_URL=https://api.liangrekui.com/
LIANGREKUI_GPT_MODEL=gpt-5.4
